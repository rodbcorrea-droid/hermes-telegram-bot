# =============================================================================
# Brandão Correa Assessoria Jurídica — Bot Hermes (Versão Unificada)
# =============================================================================
# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA versione o arquivo .env com dados sensíveis.
# =============================================================================

# ---------------------------------------------------------------------------
# Servidor Express
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

# ---------------------------------------------------------------------------
# Telegram Bot
# ---------------------------------------------------------------------------
# Token do bot obtido via @BotFather no Telegram
TELEGRAM_BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# URL pública que receberá os webhooks (deve ser HTTPS em produção)
TELEGRAM_WEBHOOK_URL=https://seu-dominio.com/webhook/telegram

# Token secreto para validar a origem do webhook (opcional mas recomendado)
TELEGRAM_WEBHOOK_SECRET=um-token-secreto-para-validar-origem

# ---------------------------------------------------------------------------
# Bitrix24 CRM — REST API
# ---------------------------------------------------------------------------
# Domínio do seu portal Bitrix24 (sem https:// e sem barra final)
# Exemplo: brandaocorrea.bitrix24.com.br
BITRIX24_DOMAIN=seuportal.bitrix24.com.br

# Webhook de entrada (Inbound Webhook) — o token gerado pelo Bitrix24
# para o endpoint REST. A URL final é montada automaticamente:
#   https://{domain}/rest/{user_id}/{webhook_token}/method
BITRIX24_USER_ID=1
BITRIX24_WEBHOOK_TOKEN=seu_webhook_token_aqui

# ID do Canal Aberto (Open Channel) configurado no Bitrix24
# conectado ao Telegram da Brandão Correa
BITRIX24_OPEN_CHANNEL_ID=1

# ID interno da operadora Alice no Bitrix24 (user ID)
BITRIX24_OPERATOR_ALICE_ID=1

# ---------------------------------------------------------------------------
# Hermes IA — NLP / LLM (OpenAI, Anthropic ou compatível)
# ---------------------------------------------------------------------------
# Provedor: openai | anthropic | custom
HERMES_AI_PROVIDER=openai

# Chave da API do provedor de LLM
HERMES_AI_API_KEY=sk-sua-chave-aqui

# Modelo a ser utilizado (ex: gpt-4o-mini, claude-haiku-4-5)
HERMES_AI_MODEL=gpt-4o-mini

# URL base customizada (opcional — para proxies ou endpoints self-hosted)
# Deixe vazio para usar o endpoint padrão do provedor
HERMES_AI_BASE_URL=

# ---------------------------------------------------------------------------
# Contingência (fallback)
# ---------------------------------------------------------------------------
# Telefone/WhatsApp de contingência exibido ao cliente em caso de falha
FALLBACK_PHONE=(65) 99679-4931

# ---------------------------------------------------------------------------
# Agendamento (Booking)
# ---------------------------------------------------------------------------
# URL externa de agendamento (Calendly, Bitrix24 Booking, etc.)
# Se vazio, será usado o link nativo do Bitrix24 Resource Booking
BOOKING_URL=
